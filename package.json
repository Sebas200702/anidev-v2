{
  "name": "anidev-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/core/auth/better-auth.ts",
    "auth:migrate": "npx @better-auth/cli@latest migrate --config src/core/auth/better-auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:prerelease": "standard-version --prerelease",
    "release:first": "standard-version --first-release",
    "release:dry": "standard-version --dry-run",
    "format": "prettier --write . "
  },
  "dependencies": {
    "@astrojs/react": "5.0.2",
    "@libsql/client": "0.17.0",
    "@nurodev/astro-bun": "2.1.2",
    "@sentry/astro": "10.43.0",
    "@sentry/node": "10.43.0",
    "@sentry/react": "10.43.0",
    "@tailwindcss/vite": "4.2.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@upstash/redis": "1.37.0",
    "astro": "6.1.2",
    "astro-font": "1.1.0",
    "better-auth": "1.5.5",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "tailwind-animations": "1.0.1",
    "tailwindcss": "4.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/pino": "7.0.5",
    "drizzle-kit": "0.31.10",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.6.12",
    "standard-version": "9.5.0",
    "tsx": "4.21.0"
  }
}
